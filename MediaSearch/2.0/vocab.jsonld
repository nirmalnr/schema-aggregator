    "owl": "http://www.w3.org/2002/07/owl#",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "MediaSearch": "beckn:MediaSearch",
    "augment_text_search": "beckn:augment_text_search",
    "contentType": "beckn:contentType",
    "endMs": "beckn:endMs",
    "goals": "beckn:goals",
    "id": "beckn:id",
    "language": "beckn:language",
    "media": "beckn:media",
    "options": "beckn:options",
    "restrict_results_to_media_proximity": "beckn:restrict_results_to_media_proximity",
    "startMs": "beckn:startMs",
    "textHint": "beckn:textHint",
    "type": "beckn:type",
    "url": "beckn:url"
  },
  "@graph": [
    {
      "@id": "beckn:MediaSearch",
      "@type": "rdfs:Class",
      "rdfs:label": "Media Search",
      "rdfs:comment": "Container for multimodal search inputs and configuration. Supports searching through **images, audio notes, and videos** alongside text, filters, and spatial predicates. For GET, this object should be JSON-encoded and URL-escaped."
    },
    {
      "@id": "beckn:media",
      "@type": "rdf:Property",
      "rdfs:label": "media",
      "rdfs:comment": "One or more references to **images, audio notes, or videos** supplied as part of a multimodal search. Each entry references a media resource accessible via HTTPS or data URI."
    },
    {
      "@id": "beckn:options",
      "@type": "rdf:Property",
      "rdfs:label": "options",
      "rdfs:comment": "Options controlling how the discovery engine interprets the supplied media — e.g., whether to perform OCR/ASR, semantic similarity, or object detection."
    }
  ]
}
