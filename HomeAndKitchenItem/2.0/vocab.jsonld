    "indoorOnly": "beckn:indoorOnly",
    "installation": "beckn:installation",
    "notes": "beckn:notes",
    "outdoorOnly": "beckn:outdoorOnly",
    "providedBySeller": "beckn:providedBySeller",
    "required": "beckn:required",
