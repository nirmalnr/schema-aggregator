{
  "@context": {
    "@import": "https://schema.beckn.io/core/v2/context.jsonld#generalised",
    "schema": "https://schema.org/",
    "beckn": "https://schema.beckn.io/LinkedData/v2.1/context.jsonld",
    "coa": "https://schema.beckn.io/CourseOfferAttributes#",
    "coa:pricingType": {
      "@id": "coa:pricingType"
    },
    "coa:seatsAvailable": {
      "@id": "coa:seatsAvailable"
    },
    "coa:enrollmentDeadline": {
      "@id": "schema:applicationDeadline"
    },
    "coa:offerValidity": {
      "@id": "schema:validityPeriod"
    },
    "coa:sponsorshipBody": {
      "@id": "coa:sponsorshipBody"
    },
    "coa:eligibilityConstraints": {
      "@id": "coa:eligibilityConstraints",
      "@container": "@list"
    },
    "schema:validFrom": {
      "@id": "schema:validFrom"
    },
    "schema:validThrough": {
      "@id": "schema:validThrough"
    },
    "pricing_type": "beckn:pricing_type",
    "seats_available": "beckn:seats_available",
    "enrollment_deadline": "beckn:enrollment_deadline",
    "offer_validity": "beckn:offer_validity",
    "sponsorship_body": "beckn:sponsorship_body",
    "eligibility_constraints": "beckn:eligibility_constraints",
    "PricingType": "coa:PricingType",
    "CourseOfferAttributes": "beckn:CourseOfferAttributes",
    "end": "beckn:end",
    "start": "beckn:start"
  }
}
