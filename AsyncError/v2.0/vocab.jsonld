{
  "@context": {
    "beckn": "https://schema.beckn.io/LinkedData/v2.1/context.jsonld",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "AsyncError": "beckn:AsyncError",
    "errorCode": "beckn:errorCode",
    "errorMessage": "beckn:errorMessage"
  },
  "@graph": [
    {
      "@id": "beckn:AsyncError",
      "@type": "rdfs:Class",
      "rdfs:label": "AsyncError",
      "rdfs:comment": "Error returned asynchronously during a callback. Wraps the base `Error` schema with JSON-LD type annotations to allow linked-data processing.\n\nThis schema is part of the Long Term Support of Beckn Protocol V2.0 API specification and MUST NOT be extended. Any domain-specific extension must use the property of this schema which is of type Attribute."
    }
  ]
}
