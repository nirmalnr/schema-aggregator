{
  "@context": {
    "@version": 1.1,
    "beckn": "https://schema.beckn.io/LinkedData/v2.1/context.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "Entitlement": "beckn:Entitlement",
    "@type": "beckn:@type",
    "credentials": "beckn:credentials",
    "descriptor": "beckn:descriptor",
    "id": "beckn:id",
    "resource": "beckn:resource"
  },
  "@graph": [
    {
      "@id": "beckn:Entitlement",
      "@type": "rdfs:Class",
      "rdfs:label": "Entitlement",
      "rdfs:comment": "A contractually granted, policy-governed right that allows a specific party to access, use, or claim a defined economic resource within stated scope and validity constraints. It represents the enforceable permission created by an order, independent of the credential used to exercise it."
    },
    {
      "@id": "beckn:@context",
      "@type": "rdf:Property",
      "rdfs:label": "@context",
      "rdfs:comment": "CPD"
    },
    {
      "@id": "beckn:@type",
      "@type": "rdf:Property",
      "rdfs:label": "@type",
      "rdfs:comment": "The domain-specific type of entitlement that allows domains to extend this schema"
    },
    {
      "@id": "beckn:id",
      "@type": "rdf:Property",
      "rdfs:label": "id",
      "rdfs:comment": "A unique identifier for this entitlement within the entitlement provider's namespace"
    },
    {
      "@id": "beckn:resource",
      "@type": "rdf:Property",
      "rdfs:label": "resource",
      "rdfs:comment": "The resource being availed or accessed against this entitlement"
    },
    {
      "@id": "beckn:descriptor",
      "@type": "rdf:Property",
      "rdfs:label": "descriptor",
      "rdfs:comment": "Human-readable information regarding the entitlement like QR-code images, attached documents containing terms and conditions, video or audio files instructing the user on how to use the entitlement"
    },
    {
      "@id": "beckn:credentials",
      "@type": "rdf:Property",
      "rdfs:label": "credentials",
      "rdfs:comment": "TODO: Description Needed - credentials"
    }
  ]
}
