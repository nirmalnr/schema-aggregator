{
  "@context": {
    "schema": "https://schema.org/",
    "beckn": "https://schema.beckn.io/",
    "cv": "https://schema.beckn.io/CodedValue#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",

    "_comment_keywords": "@context and @type inside CodedValue instances are JSON-LD keywords — they self-resolve and require no mapping here.",

    "CodedValue": "cv:CodedValue",

    "code": {
      "@id": "cv:code"
    },
    "display": {
      "@id": "cv:display"
    }
  }
}
