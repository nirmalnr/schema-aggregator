{
    "@context": [
        "https://schema.nfh.global/espiGreenButton/v1.0/context.jsonld",
        "https://schema.nfh.global/EnergyCustomerProfile/context.jsonld",
        {
            "@version": 1.1,
            "@protected": true,
            "id": "@id",
            "type": "@type",
            "schema": "https://schema.org/",
            "xsd": "http://www.w3.org/2001/XMLSchema#",
            "deg": "https://schema.nfh.global/deg/",

            "EnergyMeterDataCredential": {
                "@id": "deg:EnergyMeterDataCredential",
                "@context": {
                    "@version": 1.1,
                    "@protected": true,
                    "id": "@id",
                    "type": "@type",
                    "meterDataGB": {
                        "@id": "deg:meterDataGB",
                        "@type": "@id",
                        "@context": {
                            "@version": 1.1,
                            "@protected": true,
                            "timeZone": {
                                "@id": "deg:timeZone",
                                "@type": "xsd:string"
                            }
                        }
                    }
                }
            }
        }
    ]
}
