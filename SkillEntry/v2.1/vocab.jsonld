{
  "@context": {
    "beckn": "https://schema.beckn.io/LinkedData/v2.1/context.jsonld",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "SkillEntry": "beckn:SkillEntry",
    "attested": "beckn:attested",
    "category": "beckn:category",
    "level": "beckn:level",
    "proof_request_url": "beckn:proof_request_url",
    "subtype": "beckn:subtype"
  },
  "@graph": [
    {
      "@id": "beckn:SkillEntry",
      "@type": "rdfs:Class",
      "rdfs:label": "SkillEntry",
      "rdfs:comment": "A single skill, qualification, or credential held by a candidate. The attested flag and proof_request_url are optional — allowing the schema to function in early-stage ecosystems where VC infrastructure is not yet universal. As VCs become available for specific skills, the proof_request_url can be populated without any schema change."
    },
    {
      "@id": "beckn:attested",
      "@type": "rdf:Property",
      "rdfs:label": "attested",
      "rdfs:comment": "Whether this skill entry is backed by a verifiable credential (VC). false = self-declared (no VC yet); true = VC exists and is resolvable via proof_request_url. Employers can discover self-declared skills but know they are unverified."
    },
    {
      "@id": "beckn:category",
      "@type": "rdf:Property",
      "rdfs:label": "category",
      "rdfs:comment": "Broad class of the credential or skill held."
    },
    {
      "@id": "beckn:level",
      "@type": "rdf:Property",
      "rdfs:label": "level",
      "rdfs:comment": "Optional proficiency or qualification level. Examples: \"BEGINNER\", \"PROFESSIONAL\", \"ADVANCED\", \"3_YEARS_EXP\", \"NQF_Level_4\"."
    },
    {
      "@id": "beckn:proof_request_url",
      "@type": "rdf:Property",
      "rdfs:label": "proof_request_url",
      "rdfs:comment": "URL of the DeDi proof-request endpoint scoped to this specific credential. Only present when attested = true. An employer BAP can call this endpoint to trigger a Verifiable Presentation (VP) request. The VC payload itself never leaves the holder's wallet — only a signed verification response is returned by the orchestrator. Example: \"https://dedi.example.net/proof-request/did:ex:123/skill/AWS_SAA\""
    },
    {
      "@id": "beckn:subtype",
      "@type": "rdf:Property",
      "rdfs:label": "subtype",
      "rdfs:comment": "Specific skill or credential. Examples: \"AWS_SAA\", \"BTECH_CS\", \"LMV_LICENSE\", \"Java_SE_11\", \"CNC_Operator_Level2\"."
    }
  ]
}
