{
  "@context": {
    "beckn": "https://schema.beckn.io/LinkedData/v2.1/context.jsonld",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "TimePeriod": "beckn:TimePeriod",
    "endDate": "beckn:endDate",
    "endTime": "beckn:endTime",
    "startDate": "beckn:startDate",
    "startTime": "beckn:startTime"
  },
  "@graph": [
    {
      "@id": "beckn:TimePeriod",
      "@type": "rdfs:Class",
      "rdfs:label": "TimePeriod",
      "rdfs:comment": "Time window with date-time precision for availability/validity\n\nThis schema is part of the Long Term Support of Beckn Protocol V2.0 API specification and MUST NOT be extended. Any domain-specific extension must use the property of this schema which is of type Attribute."
    },
    {
      "@id": "beckn:startDate",
      "@type": "rdf:Property",
      "rdfs:label": "startDate",
      "rdfs:comment": "Start instant (inclusive)"
    },
    {
      "@id": "beckn:endDate",
      "@type": "rdf:Property",
      "rdfs:label": "endDate",
      "rdfs:comment": "End instant (exclusive or inclusive per domain semantics)"
    },
    {
      "@id": "beckn:startTime",
      "@type": "rdf:Property",
      "rdfs:label": "startTime",
      "rdfs:comment": "Start time of the time period"
    },
    {
      "@id": "beckn:endTime",
      "@type": "rdf:Property",
      "rdfs:label": "endTime",
      "rdfs:comment": "End time of the time period"
    }
  ]
}
