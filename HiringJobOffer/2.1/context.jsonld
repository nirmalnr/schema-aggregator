    },
    "remarks": {
      "@id": "hjoa:remarks"
    },
    "SalarySpecification": "salspec:SalarySpecification",
    "salary_min": {
      "@id": "salspec:salary_min"
    },
    "salary_max": {
      "@id": "salspec:salary_max"
    },
