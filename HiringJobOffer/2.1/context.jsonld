    "salary_specification": {
      "@id": "hjoa:salary_specification"
    },
    "benefits": {
      "@id": "hjoa:benefits"
    },
    "other_benefits": {
      "@id": "hjoa:other_benefits"
    },
    "insurance_provided": {
      "@id": "hjoa:insurance_provided"
    },
    "accommodation_provided": {
      "@id": "hjoa:accommodation_provided"
    },
    "equity_offered": {
      "@id": "hjoa:equity_offered"
    },
    "joining_date": {
      "@id": "hjoa:joining_date"
    },
    "contract_duration": {
      "@id": "hjoa:contract_duration"
    },
    "probation_period": {
      "@id": "hjoa:probation_period"
    },
    "notice_period": {
      "@id": "hjoa:notice_period"
    },
    "offer_issued_at": {
      "@id": "hjoa:offer_issued_at"
    },
    "offer_validity": {
