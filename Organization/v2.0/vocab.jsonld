{
  "@context": {
    "@version": 1.1,
    "beckn": "https://schema.beckn.io/LinkedData/v2.1/context.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "Organization": "beckn:Organization",
    "@type": "beckn:@type",
    "address": "beckn:address",
    "credentials": "beckn:credentials",
    "email": "beckn:email",
    "id": "beckn:id",
    "name": "beckn:name",
    "organizationAttributes": "beckn:organizationAttributes",
    "skills": "beckn:skills",
    "telephone": "beckn:telephone"
  },
  "@graph": [
    {
      "@id": "beckn:Organization",
      "@type": "rdfs:Class",
      "rdfs:label": "Organization",
      "rdfs:comment": "An organization such as a company, non-profit, or governmental institution. Modeled after schema.org/Organization."
    },
    {
      "@id": "beckn:@context",
      "@type": "rdf:Property",
      "rdfs:label": "@context",
      "rdfs:comment": "TODO: Description Needed - @context"
    },
    {
      "@id": "beckn:@type",
      "@type": "rdf:Property",
      "rdfs:label": "@type",
      "rdfs:comment": "TODO: Description Needed - @type"
    },
    {
      "@id": "beckn:id",
      "@type": "rdf:Property",
      "rdfs:label": "id",
      "rdfs:comment": "Unique identifier for the organization"
    },
    {
      "@id": "beckn:name",
      "@type": "rdf:Property",
      "rdfs:label": "name",
      "rdfs:comment": "Name of the organization"
    },
    {
      "@id": "beckn:email",
      "@type": "rdf:Property",
      "rdfs:label": "email",
      "rdfs:comment": "Email address"
    },
    {
      "@id": "beckn:telephone",
      "@type": "rdf:Property",
      "rdfs:label": "telephone",
      "rdfs:comment": "Telephone number"
    },
    {
      "@id": "beckn:address",
      "@type": "rdf:Property",
      "rdfs:label": "address",
      "rdfs:comment": "Physical address"
    },
    {
      "@id": "beckn:credentials",
      "@type": "rdf:Property",
      "rdfs:label": "credentials",
      "rdfs:comment": "Credentials held by the organization"
    },
    {
      "@id": "beckn:skills",
      "@type": "rdf:Property",
      "rdfs:label": "skills",
      "rdfs:comment": "Skills or capabilities of the organization"
    },
    {
      "@id": "beckn:organizationAttributes",
      "@type": "rdf:Property",
      "rdfs:label": "organization Attributes",
      "rdfs:comment": "Extensible attribute pack for jurisdictional or domain-specific organization properties"
    }
  ]
}
