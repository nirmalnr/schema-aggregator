{
  "@context": {
    "@version": 1.1,
    "beckn": "https://schema.beckn.io/LinkedData/v2.1/context.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "MediaInput": "beckn:MediaInput",
    "contentType": "beckn:contentType",
    "endMs": "beckn:endMs",
    "id": "beckn:id",
    "language": "beckn:language",
    "startMs": "beckn:startMs",
    "textHint": "beckn:textHint",
    "type": "beckn:type",
    "url": "beckn:url"
  },
  "@graph": [
    {
      "@id": "beckn:MediaInput",
      "@type": "rdfs:Class",
      "rdfs:label": "Media Input",
      "rdfs:comment": "Reference to an image, audio clip, or video used for multimodal search."
    },
    {
      "@id": "beckn:id",
      "@type": "rdf:Property",
      "rdfs:label": "id",
      "rdfs:comment": "Client-supplied identifier for this media input."
    },
    {
      "@id": "beckn:type",
      "@type": "rdf:Property",
      "rdfs:label": "type",
      "rdfs:comment": "Media category."
    },
    {
      "@id": "beckn:url",
      "@type": "rdf:Property",
      "rdfs:label": "url",
      "rdfs:comment": "HTTPS URL or data URI pointing to the media resource."
    },
    {
      "@id": "beckn:contentType",
      "@type": "rdf:Property",
      "rdfs:label": "content Type",
      "rdfs:comment": "MIME type, e.g., image/jpeg, audio/mpeg, video/mp4."
    },
    {
      "@id": "beckn:textHint",
      "@type": "rdf:Property",
      "rdfs:label": "text Hint",
      "rdfs:comment": "Optional pre-extracted text (OCR/ASR) for search augmentation."
    },
    {
      "@id": "beckn:language",
      "@type": "rdf:Property",
      "rdfs:label": "language",
      "rdfs:comment": "Language code (BCP-47) of `textHint` or spoken audio."
    },
    {
      "@id": "beckn:startMs",
      "@type": "rdf:Property",
      "rdfs:label": "start Ms",
      "rdfs:comment": "Optional start offset in milliseconds (for audio/video segments)."
    },
    {
      "@id": "beckn:endMs",
      "@type": "rdf:Property",
      "rdfs:label": "end Ms",
      "rdfs:comment": "Optional end offset in milliseconds (for audio/video segments)."
    }
  ]
}
