{
  "@context": {
    "@version": 1.1,
    "beckn": "https://schema.beckn.io/LinkedData/v2.1/context.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "Quote": "beckn:Quote",
    "@type": "beckn:@type",
    "breakup": "beckn:breakup",
    "currency": "beckn:currency",
    "end": "beckn:end",
    "id": "beckn:id",
    "itemId": "beckn:itemId",
    "offerId": "beckn:offerId",
    "price": "beckn:price",
    "quantity": "beckn:quantity",
    "start": "beckn:start",
    "title": "beckn:title",
    "type": "beckn:type",
    "validity": "beckn:validity",
    "value": "beckn:value"
  },
  "@graph": [
    {
      "@id": "beckn:Quote",
      "@type": "rdfs:Class",
      "rdfs:label": "Quote",
      "rdfs:comment": "A price quote generated by a BPP for a specific selection of offers and fulfillment options."
    },
    {
      "@id": "beckn:@context",
      "@type": "rdf:Property",
      "rdfs:label": "@context",
      "rdfs:comment": "JSON-LD context URI."
    },
    {
      "@id": "beckn:@type",
      "@type": "rdf:Property",
      "rdfs:label": "@type",
      "rdfs:comment": "JSON-LD type identifier."
    },
    {
      "@id": "beckn:id",
      "@type": "rdf:Property",
      "rdfs:label": "id",
      "rdfs:comment": "Unique identifier for this quote."
    },
    {
      "@id": "beckn:price",
      "@type": "rdf:Property",
      "rdfs:label": "price",
      "rdfs:comment": "Total quoted price inclusive of all charges and discounts."
    },
    {
      "@id": "beckn:breakup",
      "@type": "rdf:Property",
      "rdfs:label": "breakup",
      "rdfs:comment": "Itemised breakdown of the total quoted price."
    },
    {
      "@id": "beckn:validity",
      "@type": "rdf:Property",
      "rdfs:label": "validity",
      "rdfs:comment": "Validity window within which the quote is honoured."
    }
  ]
}
