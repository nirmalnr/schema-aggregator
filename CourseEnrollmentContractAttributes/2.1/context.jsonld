{
  "@context": {
    "@import": "https://schema.beckn.io/core/v2/context.jsonld#generalised",
    "schema": "https://schema.org/",
    "beckn": "https://schema.beckn.io/LinkedData/v2.1/context.jsonld",
    "ceca": "https://schema.beckn.io/CourseEnrollmentContractAttributes#",
    "vs": "https://schema.beckn.io/VerificationSummary#",
    "ceca:enrollmentReference": {
      "@id": "ceca:enrollmentReference"
    },
    "ceca:cohortId": {
      "@id": "ceca:cohortId"
    },
    "ceca:prerequisiteVerificationSummary": {
      "@id": "ceca:prerequisiteVerificationSummary"
    },
    "ceca:credentialIssuancePending": {
      "@id": "ceca:credentialIssuancePending"
    },
    "ceca:enrolledAt": {
      "@id": "schema:dateCreated"
    },
    "vs:overallResult": {
      "@id": "vs:overallResult"
    },
    "vs:reasonCodes": {
      "@id": "vs:reasonCodes",
      "@container": "@list"
    },
    "vs:verifiedCategories": {
      "@id": "vs:verifiedCategories",
      "@container": "@list"
    },
    "vs:verifiedSubtypes": {
      "@id": "vs:verifiedSubtypes",
      "@container": "@list"
    },
    "vs:checkedAt": {
      "@id": "vs:checkedAt"
    },
    "vs:proofMetadataHash": {
      "@id": "vs:proofMetadataHash"
    },
    "enrollment_reference": "beckn:enrollment_reference",
    "cohort_id": "beckn:cohort_id",
    "prerequisite_verification_summary": "beckn:prerequisite_verification_summary",
    "credential_issuance_pending": "beckn:credential_issuance_pending",
    "enrolled_at": "beckn:enrolled_at",
    "EnrollmentContractStatus": "ceca:EnrollmentContractStatus",
    "CourseEnrollmentContractAttributes": "beckn:CourseEnrollmentContractAttributes"
  }
}
