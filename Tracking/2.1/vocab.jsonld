{
  "@context": {
    "beckn": "https://schema.beckn.io/LinkedData/v2.1/context.jsonld",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "Tracking": "beckn:Tracking",
    "@type": "beckn:@type",
    "addOns": "beckn:addOns",
    "address": "beckn:address",
    "addressCountry": "beckn:addressCountry",
    "addressLocality": "beckn:addressLocality",
    "addressRegion": "beckn:addressRegion",
    "availableAt": "beckn:availableAt",
    "availableTo": "beckn:availableTo",
    "bbox": "beckn:bbox",
    "checksum": "beckn:checksum",
    "checksumAlgorithm": "beckn:checksumAlgorithm",
    "code": "beckn:code",
    "commitmentAttributes": "beckn:commitmentAttributes",
    "commitmentIds": "beckn:commitmentIds",
    "commitments": "beckn:commitments",
    "consideration": "beckn:consideration",
    "considerationAttributes": "beckn:considerationAttributes",
    "considerationId": "beckn:considerationId",
    "considerationIds": "beckn:considerationIds",
    "contract": "beckn:contract",
    "contractAttributes": "beckn:contractAttributes",
    "coordinates": "beckn:coordinates",
    "descriptor": "beckn:descriptor",
    "docs": "beckn:docs",
    "endDate": "beckn:endDate",
    "endTime": "beckn:endTime",
    "extendedAddress": "beckn:extendedAddress",
    "fulfillmentIds": "beckn:fulfillmentIds",
    "geo": "beckn:geo",
    "geometries": "beckn:geometries",
    "id": "beckn:id",
    "keyId": "beckn:keyId",
    "label": "beckn:label",
    "longDesc": "beckn:longDesc",
    "mediaFile": "beckn:mediaFile",
    "mimeType": "beckn:mimeType",
    "name": "beckn:name",
    "offer": "beckn:offer",
    "offerAttributes": "beckn:offerAttributes",
    "participantAttributes": "beckn:participantAttributes",
    "participants": "beckn:participants",
    "performance": "beckn:performance",
    "performanceAttributes": "beckn:performanceAttributes",
    "postalCode": "beckn:postalCode",
    "provider": "beckn:provider",
    "providerAttributes": "beckn:providerAttributes",
    "resourceAttributes": "beckn:resourceAttributes",
    "resourceIds": "beckn:resourceIds",
    "resources": "beckn:resources",
    "security": "beckn:security",
    "settlementAttributes": "beckn:settlementAttributes",
    "settlements": "beckn:settlements",
    "shortDesc": "beckn:shortDesc",
    "signature": "beckn:signature",
    "signatureAlgorithm": "beckn:signatureAlgorithm",
    "standard": "beckn:standard",
    "startDate": "beckn:startDate",
    "startTime": "beckn:startTime",
    "status": "beckn:status",
    "streetAddress": "beckn:streetAddress",
    "thumbnailImage": "beckn:thumbnailImage",
    "trackingAttributes": "beckn:trackingAttributes",
    "type": "beckn:type",
    "uri": "beckn:uri",
    "url": "beckn:url",
    "validity": "beckn:validity"
  },
  "@graph": [
    {
      "@id": "beckn:Tracking",
      "@type": "rdfs:Class",
      "rdfs:label": "Tracking",
      "rdfs:comment": "Information regarding live tracking of the fufillment of a contract\n\nThis schema is part of the Long Term Support of Beckn Protocol V2.0 API specification and MUST NOT be extended. Any domain-specific extension must use the property of this schema which is of type Attribute."
    },
    {
      "@id": "beckn:refId",
      "@type": "rdf:Property",
      "rdfs:label": "refId",
      "rdfs:comment": "Tracking reference ID for the tracking session. Could be the Order ID, Fulfillment ID, Fulfillment Stage ID, or any other unique tracking identifier"
    },
    {
      "@id": "beckn:status",
      "@type": "rdf:Property",
      "rdfs:label": "status",
      "rdfs:comment": "Property status"
    },
    {
      "@id": "beckn:url",
      "@type": "rdf:Property",
      "rdfs:label": "url",
      "rdfs:comment": "Link/handle to off-network tracking UI or endpoint."
    }
  ]
}
