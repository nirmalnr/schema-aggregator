{
  "schema": "CourseConsiderationAttributes",
  "version": "1.0.0",
  "card_template": "{{ccoa:feeCategory}} | {{ccoa:paymentSchedule}} | Subsidy: {{ccoa:subsidySource}}",
  "detail_template": "Fee: {{ccoa:feeCategory}}\nSchedule: {{ccoa:paymentSchedule}}\nInstallments: {{ccoa:installmentCount}}\nSubsidy: {{ccoa:subsidySource}}\nRefund: {{ccoa:refundPolicy}}",
  "html": "<div class=\"skilling-consideration-card\"><span class=\"badge badge-{{toLowerCase beckn:considerationAttributes.ccoa:feeCategory}}\">{{beckn:considerationAttributes.ccoa:feeCategory}}</span><span class=\"badge\">{{beckn:considerationAttributes.ccoa:paymentSchedule}}</span>{{#if beckn:considerationAttributes.ccoa:subsidySource}}<span class=\"subsidy-badge\">Subsidy: {{beckn:considerationAttributes.ccoa:subsidySource}}</span>{{/if}}</div>",
  "html_detail": "<div class=\"skilling-consideration-detail\"><div class=\"detail-section\"><h4>Fee Structure</h4><div class=\"detail-grid\"><div class=\"detail-item\"><label>Fee Category</label><span class=\"badge badge-{{toLowerCase beckn:considerationAttributes.ccoa:feeCategory}}\">{{beckn:considerationAttributes.ccoa:feeCategory}}</span></div><div class=\"detail-item\"><label>Payment Schedule</label><span class=\"badge\">{{beckn:considerationAttributes.ccoa:paymentSchedule}}</span></div>{{#if beckn:considerationAttributes.ccoa:installmentCount}}<div class=\"detail-item\"><label>Installments</label><span>{{beckn:considerationAttributes.ccoa:installmentCount}}</span></div>{{/if}}{{#if beckn:considerationAttributes.ccoa:subsidySource}}<div class=\"detail-item\"><label>Sponsored By</label><span>{{beckn:considerationAttributes.ccoa:subsidySource}}</span></div>{{/if}}{{#if beckn:considerationAttributes.ccoa:refundPolicy}}<div class=\"detail-item\"><label>Refund Policy</label><span>{{beckn:considerationAttributes.ccoa:refundPolicy}}</span></div>{{/if}}</div></div></div>"
}
