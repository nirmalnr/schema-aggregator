{
  "@context": {
    "@version": 1.1,
    "beckn": "https://schema.beckn.io/LinkedData/v2.1/context.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "SpatialConstraint": "beckn:SpatialConstraint",
    "bbox": "beckn:bbox",
    "coordinates": "beckn:coordinates",
    "distanceMeters": "beckn:distanceMeters",
    "geometries": "beckn:geometries",
    "geometry": "beckn:geometry",
    "op": "beckn:op",
    "quantifier": "beckn:quantifier",
    "srid": "beckn:srid",
    "targets": "beckn:targets",
    "type": "beckn:type"
  },
  "@graph": [
    {
      "@id": "beckn:SpatialConstraint",
      "@type": "rdfs:Class",
      "rdfs:label": "Spatial Constraint",
      "rdfs:comment": "**Spatial predicate** using **OGC CQL2 (JSON semantics)** applied to one or more geometry targets in an item. This is where clients express spatial intent. Key ideas: - `targets`: one or more **JSONPath-like** pointers that locate geometry fields within each item document (e.g., `$['availableAt'][*]['geo']`). - `op`: spatial operator (CQL2). Common ones: • `S_WITHIN` (A is completely inside B) • `S_INTERSECTS` (A intersects B) • `S_CONTAINS` (A contains B) • `S_DWITHIN` (A within distance of B) - `geometry`: **GeoJSON** literal used as the predicate reference geometry. - `distanceMeters`: required for `S_DWITHIN` when using a GeoJSON Point/shape. - `quantifier`: if a target resolves to an array, choose whether **ANY** (default), **ALL**, or **NONE** of elements must satisfy the predicate. CRS: unless otherwise stated, all coordinates are **EPSG:4326**."
    },
    {
      "@id": "beckn:op",
      "@type": "rdf:Property",
      "rdfs:label": "op",
      "rdfs:comment": "OGC CQL2 spatial operator."
    },
    {
      "@id": "beckn:targets",
      "@type": "rdf:Property",
      "rdfs:label": "targets",
      "rdfs:comment": "'One or more JSONPath-like pointers to geometry fields within the item. Example pointers: - `$[''availableAt''][*][''geo'']` (array of site Points) - `$[''itemAttributes''][''ride:dropOff''][''geo'']` (drop zone Polygon)'"
    },
    {
      "@id": "beckn:geometry",
      "@type": "rdf:Property",
      "rdfs:label": "geometry",
      "rdfs:comment": "TODO: Description Needed - geometry"
    },
    {
      "@id": "beckn:distanceMeters",
      "@type": "rdf:Property",
      "rdfs:label": "distance Meters",
      "rdfs:comment": "For `S_DWITHIN`: maximum distance in meters from the target geometry to `geometry` (e.g., \"within 5000 m of this Point\"). Ignored for other ops."
    },
    {
      "@id": "beckn:quantifier",
      "@type": "rdf:Property",
      "rdfs:label": "quantifier",
      "rdfs:comment": "'How to evaluate when `targets` resolves to an array - - **any**: at least one element matches (default) - **all**: every element must match - **none**: no element may match'"
    },
    {
      "@id": "beckn:srid",
      "@type": "rdf:Property",
      "rdfs:label": "srid",
      "rdfs:comment": "Coordinate Reference System identifier for `geometry`. Default is `\"EPSG:4326\"`. If provided, servers MAY reproject to EPSG:4326 internally."
    }
  ]
}
