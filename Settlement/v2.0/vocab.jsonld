    "Settlement": "beckn:Settlement",
    "@type": "beckn:@type",
    "considerationId": "beckn:considerationId",
    "id": "beckn:id",
    "settlementAttributes": "beckn:settlementAttributes",
    "status": "beckn:status"
  },
  "@graph": [
    {
      "@id": "beckn:Settlement",
      "@type": "rdfs:Class",
      "rdfs:label": "Settlement",
      "rdfs:comment": "This schema is part of the Long Term Support of Beckn Protocol V2.0 API specification and MUST NOT be extended. Any domain-specific extension must use the property of this schema which is of type Attribute."
    },
    {
      "@id": "beckn:id",
      "@type": "rdf:Property",
      "rdfs:label": "id",
      "rdfs:comment": "Property id"
    },
    {
      "@id": "beckn:considerationId",
      "@type": "rdf:Property",
      "rdfs:label": "considerationId",
      "rdfs:comment": "Property considerationId"
    },
    {
      "@id": "beckn:status",
      "@type": "rdf:Property",
      "rdfs:label": "status",
      "rdfs:comment": "Property status"
    },
    {
      "@id": "beckn:settlementAttributes",
      "@type": "rdf:Property",
      "rdfs:label": "settlementAttributes",
      "rdfs:comment": "Property settlementAttributes"
    }
  ]
}
