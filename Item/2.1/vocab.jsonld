      "@type": "rdf:Property",
      "rdfs:label": "id",
      "rdfs:comment": "Unique identifier for the item"
    },
    {
      "@id": "beckn:isActive",
      "@type": "rdf:Property",
      "rdfs:label": "is Active",
      "rdfs:comment": "Whether the item is active"
    },
    {
      "@id": "beckn:itemAttributes",
      "@type": "rdf:Property",
      "rdfs:label": "item Attributes",
