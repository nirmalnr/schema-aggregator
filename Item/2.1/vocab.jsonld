    },
    {
      "@id": "beckn:networkId",
      "@type": "rdf:Property",
      "rdfs:label": "network Id",
      "rdfs:comment": "Array of network identifiers for the BAP (Beckn App Provider) that offers this item"
    },
    {
      "@id": "beckn:policies",
