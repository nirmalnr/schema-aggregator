{
  "@context": {
    "@import": "https://schema.beckn.io/core/v2/context.jsonld#generalised",
    "schema": "https://schema.org/",
    "beckn": "https://schema.beckn.io/LinkedData/v2.1/context.jsonld",
    "cra": "https://schema.beckn.io/CourseResourceAttributes#",
    "cra:courseLevel": {
      "@id": "cra:courseLevel"
    },
    "cra:courseDomain": {
      "@id": "cra:courseDomain"
    },
    "cra:deliveryMode": {
      "@id": "cra:deliveryMode"
    },
    "cra:duration": {
      "@id": "schema:duration"
    },
    "cra:location": {
      "@id": "schema:location"
    },
    "cra:capacity": {
      "@id": "cra:capacity"
    },
    "cra:schedule": {
      "@id": "cra:schedule"
    },
    "cra:sessionPattern": {
      "@id": "cra:sessionPattern"
    },
    "cra:prerequisites": {
      "@id": "cra:prerequisites",
      "@container": "@list"
    },
    "cra:outcomeCredential": {
      "@id": "cra:outcomeCredential"
    },
    "cra:credentialCategory": {
      "@id": "cra:credentialCategory"
    },
    "cra:credentialName": {
      "@id": "cra:credentialName"
    },
    "cra:industryType": {
      "@id": "cra:industryType"
    },
    "schema:addressLocality": {
      "@id": "schema:addressLocality"
    },
    "schema:addressRegion": {
      "@id": "schema:addressRegion"
    },
    "schema:addressCountry": {
      "@id": "schema:addressCountry"
    },
    "schema:startDate": {
      "@id": "schema:startDate"
    },
    "schema:endDate": {
      "@id": "schema:endDate"
    },
    "course_level": "beckn:course_level",
    "course_domain": "beckn:course_domain",
    "delivery_mode": "beckn:delivery_mode",
    "duration": "beckn:duration",
    "location": "beckn:location",
    "capacity": "beckn:capacity",
    "schedule": "beckn:schedule",
    "prerequisites": "beckn:prerequisites",
    "outcome_credential": "beckn:outcome_credential",
    "industry_type": "beckn:industry_type",
    "CourseLevel": "cra:CourseLevel",
    "DeliveryMode": "cra:DeliveryMode",
    "OutcomeCredentialCategory": "cra:OutcomeCredentialCategory",
    "CourseResourceAttributes": "beckn:CourseResourceAttributes",
    "category": "beckn:category",
    "city": "beckn:city",
    "country": "beckn:country",
    "end_date": "beckn:end_date",
    "name": "beckn:name",
    "region": "beckn:region",
    "session_pattern": "beckn:session_pattern",
    "start_date": "beckn:start_date"
  }
}
