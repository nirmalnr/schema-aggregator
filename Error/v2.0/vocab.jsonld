{
  "@context": {
    "@version": 1.1,
    "beckn": "https://schema.beckn.io/LinkedData/v2.1/context.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "Error": "beckn:Error",
    "errorCode": "beckn:errorCode",
    "errorMessage": "beckn:errorMessage"
  },
  "@graph": [
    {
      "@id": "beckn:Error",
      "@type": "rdfs:Class",
      "rdfs:label": "Error",
      "rdfs:comment": "Schema definition for Error in the Beckn Protocol v2.0.1"
    },
    {
      "@id": "beckn:code",
      "@type": "rdf:Property",
      "rdfs:label": "code",
      "rdfs:comment": "Error code"
    },
    {
      "@id": "beckn:details",
      "@type": "rdf:Property",
      "rdfs:label": "details",
      "rdfs:comment": "Additional error details"
    },
    {
      "@id": "beckn:message",
      "@type": "rdf:Property",
      "rdfs:label": "message",
      "rdfs:comment": "Human-readable error message"
    }
  ]
}
