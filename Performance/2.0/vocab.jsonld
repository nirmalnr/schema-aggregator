{
  "@context": {
    "beckn": "https://schema.beckn.io/LinkedData/v2.1/context.jsonld",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "Performance": "beckn:Performance",
    "@type": "beckn:@type",
    "checksum": "beckn:checksum",
    "checksumAlgorithm": "beckn:checksumAlgorithm",
    "code": "beckn:code",
    "commitmentIds": "beckn:commitmentIds",
    "docs": "beckn:docs",
    "id": "beckn:id",
    "keyId": "beckn:keyId",
    "label": "beckn:label",
    "longDesc": "beckn:longDesc",
    "mediaFile": "beckn:mediaFile",
    "mimeType": "beckn:mimeType",
    "name": "beckn:name",
    "performanceAttributes": "beckn:performanceAttributes",
    "security": "beckn:security",
    "shortDesc": "beckn:shortDesc",
    "signature": "beckn:signature",
    "signatureAlgorithm": "beckn:signatureAlgorithm",
    "standard": "beckn:standard",
    "status": "beckn:status",
    "thumbnailImage": "beckn:thumbnailImage",
    "uri": "beckn:uri",
    "url": "beckn:url"
  },
  "@graph": [
    {
      "@id": "beckn:Performance",
      "@type": "rdfs:Class",
      "rdfs:label": "Performance",
      "rdfs:comment": "Generalized execution/performance unit. This is where downstream objects bind:\n- Fulfillment-like details (where/when/how)\n- Tracking handles\n- Support touchpoints\n- Status updates\n\nA minimal envelope that carries identity, status, and a performanceAttributes\nbag that holds the concrete domain-specific delivery schema.\n\nDomain specification authors can attach rich context and types via `performanceAttributes`.\n\nFor example, Hyperlocal delivery details (pickup/delivery locations, items shipped, agent, etc.)\nare placed inside performanceAttributes using a well-known domain schema such as\nHyperlocalDelivery. Use the generic Attributes schema when no well-known\ndomain schema exists.\n\nThis schema is part of the Long Term Support of Beckn Protocol V2.0 API specification and MUST NOT be extended. Any domain-specific extension must use the property of this schema which is of type Attribute."
    },
    {
      "@id": "beckn:id",
      "@type": "rdf:Property",
      "rdfs:label": "id",
      "rdfs:comment": "Unique identifier for this fulfillment record."
    },
    {
      "@id": "beckn:status",
      "@type": "rdf:Property",
      "rdfs:label": "status",
      "rdfs:comment": "Current status of this fulfillment, expressed as a Descriptor. Use Descriptor.code for machine-readable status values."
    },
    {
      "@id": "beckn:commitmentIds",
      "@type": "rdf:Property",
      "rdfs:label": "commitmentIds",
      "rdfs:comment": "Property commitmentIds"
    },
    {
      "@id": "beckn:performanceAttributes",
      "@type": "rdf:Property",
      "rdfs:label": "performanceAttributes",
      "rdfs:comment": "Domain-specific extension attributes for this fulfillment. Use beckn:HyperlocalDelivery (aligned with schema:ParcelDelivery) for hyperlocal physical delivery. Use the generic Attributes schema for other fulfillment types where no well-known domain schema exists."
    }
  ]
}
