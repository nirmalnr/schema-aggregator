      "@id": "hjra:industry_type"
    },
    "functional_area": {
      "@id": "hjra:functional_area"
    },
    "vacancy_count": {
      "@id": "hjra:vacancy_count"
    },
    "is_urgent": {
      "@id": "hjra:is_urgent"
    },
    "application_deadline": {
      "@id": "hjra:application_deadline"
    },
    "application_instructions": {
      "@id": "hjra:application_instructions"
    },
    "operator_reputation": {
