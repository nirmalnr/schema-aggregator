      "@id": "hjra:location"
    },
    "shift_type": {
      "@id": "hjra:shift_type"
    },
    "working_hours": {
      "@id": "hjra:working_hours"
    },
    "contract_duration": {
      "@id": "hjra:contract_duration"
    },
    "experience_level": {
      "@id": "hjra:experience_level"
    },
    "min_experience_years": {
      "@id": "hjra:min_experience_years"
    },
    "max_experience_years": {
      "@id": "hjra:max_experience_years"
    },
    "skills_required": {
      "@id": "hjra:skills_required"
    },
    "requirements": {
      "@id": "hjra:requirements"
    },
