{
  "schema": "HiringJobResource",
  "version": "2.1.0",
  "card_template": "{{job_title}} | {{job_type}} | {{work_mode}} | {{location.city}}, {{location.state}}",
  "detail_template": "{{job_title}}\nType: {{job_type}} | Mode: {{work_mode}}\nLocation: {{location.city}}, {{location.state}}, {{location.country}}\nExperience: {{experience_level}} ({{min_experience_years}}-{{max_experience_years}} yrs)\nDeadline: {{application_deadline}}",
  "html": "<div class=\"hiring-job-resource-card\" data-resource-id=\"{{beckn:id}}\"><div style='padding:12px;'><h3 style='margin:0 0 4px;'>{{beckn:descriptor.schema:name}}</h3><p style='margin:0 0 8px;font-size:0.85rem;color:#555;'>{{beckn:descriptor.beckn:shortDesc}}</p><div style='display:flex;gap:6px;flex-wrap:wrap;margin-bottom:8px;'><span class=\"badge\">{{beckn:resourceAttributes.job_type}}</span><span class=\"badge\">{{beckn:resourceAttributes.work_mode}}</span><span class=\"badge\">{{beckn:resourceAttributes.experience_level}}</span></div><p style='font-size:0.85rem;'>📍 {{beckn:resourceAttributes.location.city}}, {{beckn:resourceAttributes.location.state}}</p>{{#if beckn:resourceAttributes.is_urgent}}<span style='color:#e53e3e;font-size:0.8rem;font-weight:600;'>⚡ Urgent</span>{{/if}}</div></div>",
  "html_detail": "<div class=\"hiring-job-resource-detail\" data-resource-id=\"{{beckn:id}}\"><div style='padding:16px;'><h2>{{beckn:descriptor.schema:name}}</h2><p>{{beckn:descriptor.schema:description}}</p><div style='display:flex;gap:8px;flex-wrap:wrap;margin:12px 0;'><span class=\"badge\">{{beckn:resourceAttributes.job_type}}</span><span class=\"badge\">{{beckn:resourceAttributes.work_mode}}</span><span class=\"badge\">{{beckn:resourceAttributes.experience_level}}</span></div><h4>Location</h4><p>{{beckn:resourceAttributes.location.city}}, {{beckn:resourceAttributes.location.state}}, {{beckn:resourceAttributes.location.country}}</p><h4>Experience</h4><p>{{beckn:resourceAttributes.min_experience_years}}–{{beckn:resourceAttributes.max_experience_years}} years</p><h4>Skills Required</h4><div style='display:flex;gap:4px;flex-wrap:wrap;'>{{#each beckn:resourceAttributes.skills_required}}<span class=\"skill-chip\">{{this}}</span>{{/each}}</div><h4>Vacancies</h4><p>{{beckn:resourceAttributes.vacancy_count}}</p>{{#if beckn:resourceAttributes.application_deadline}}<h4>Apply By</h4><p>{{beckn:resourceAttributes.application_deadline}}</p>{{/if}}</div></div>"
}
