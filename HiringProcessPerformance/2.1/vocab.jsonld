{
  "@import": "https://schema.beckn.io/core/v2/vocab.jsonld",
  "@context": {
    "hppa": "https://schema.beckn.io/HiringProcessPerformance#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#"
  },
  "@graph": [
    {
      "@id": "hppa:ProcessStep",
      "@type": "skos:ConceptScheme",
      "rdfs:label": "Hiring Process Step Type",
      "skos:hasTopConcept": [
        {
          "@id": "hppa:CV_REVIEW",
          "skos:prefLabel": "CV Review"
        },
        {
          "@id": "hppa:TELEPHONIC",
          "skos:prefLabel": "Telephonic Screen"
        },
        {
          "@id": "hppa:VIDEO",
