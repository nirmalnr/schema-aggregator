        },
        {
          "@id": "hppa:WRITTEN_TEST",
          "skos:prefLabel": "Written Test"
        },
        {
          "@id": "hppa:TECHNICAL_TEST",
          "skos:prefLabel": "Technical Assessment"
        },
        {
          "@id": "hppa:BACKGROUND_CHECK",
          "skos:prefLabel": "Background Check"
        },
        {
          "@id": "hppa:REFERENCE_CHECK",
          "skos:prefLabel": "Reference Check"
        },
        {
          "@id": "hppa:OFFER_EXTENDED",
          "skos:prefLabel": "Offer Extended"
        },
        {
          "@id": "hppa:OTHER",
          "skos:prefLabel": "Other"
        }
      ]
    },
    {
      "@id": "hppa:StepResult",
      "@type": "skos:ConceptScheme",
      "rdfs:label": "Process Step Result",
      "skos:hasTopConcept": [
        {
          "@id": "hppa:PASS",
          "skos:prefLabel": "Pass"
        },
        {
          "@id": "hppa:FAIL",
          "skos:prefLabel": "Fail"
        },
        {
          "@id": "hppa:ON_HOLD",
          "skos:prefLabel": "On Hold \u2014 deferred"
        },
        {
          "@id": "hppa:PENDING",
          "skos:prefLabel": "Pending \u2014 not yet evaluated"
        }
      ]
    },
    {
      "@id": "hppa:InterviewFormat",
      "@type": "skos:ConceptScheme",
      "rdfs:label": "Interview Format",
      "skos:hasTopConcept": [
        {
          "@id": "hppa:ONE_ON_ONE",
          "skos:prefLabel": "One-on-One"
        },
        {
          "@id": "hppa:PANEL",
