{
  "$id": "https://schema.beckn.io/Consideration/v2.0",
  "x-iri": "https://schema.beckn.io/Consideration/v2.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "description": "Generalized representation of value exchanged under a Contract.  Consideration is domain-neutral and may represent: - Monetary value - Credits / tokens - Asset transfer - Service exchange - Compliance artifact",
  "required": [
    "id",
    "status"
  ],
  "properties": {
    "id": {
      "description": "Identifier of this consideration",
      "type": "string"
    },
    "status": {
      "$ref": "https://schema.beckn.io/Descriptor/v2.0/schema.json"
    },
    "considerationAttributes": {
      "$ref": "https://schema.beckn.io/Attributes/v2.0/schema.json"
    }
  }
}
