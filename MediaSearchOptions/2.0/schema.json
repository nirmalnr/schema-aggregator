{
  "$id": "https://schema.beckn.io/MediaSearchOptions/v2.0",
  "x-iri": "https://schema.beckn.io/MediaSearchOptions/v2.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "goals": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "visual-similarity",
          "visual-object-detect",
          "text-from-image",
          "text-from-audio",
          "semantic-audio-match",
          "semantic-video-match"
        ]
      }
    },
    "augment_text_search": {
      "type": "boolean",
      "default": true
    },
    "restrict_results_to_media_proximity": {
      "type": "boolean",
      "default": false
    }
  },
  "additionalProperties": false
}
