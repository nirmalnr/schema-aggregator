{
  "@context": {
    "@version": 1.1,
    "beckn": "https://schema.beckn.io/LinkedData/v2.1/context.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "MediaSearchOptions": "beckn:MediaSearchOptions",
    "augment_text_search": "beckn:augment_text_search",
    "goals": "beckn:goals",
    "restrict_results_to_media_proximity": "beckn:restrict_results_to_media_proximity"
  },
  "@graph": [
    {
      "@id": "beckn:MediaSearchOptions",
      "@type": "rdfs:Class",
      "rdfs:label": "Media Search Options",
      "rdfs:comment": "How the discovery engine should use the provided media inputs."
    },
    {
      "@id": "beckn:goals",
      "@type": "rdf:Property",
      "rdfs:label": "goals",
      "rdfs:comment": "Desired processing goals for the media."
    },
    {
      "@id": "beckn:augmentTextSearch",
      "@type": "rdf:Property",
      "rdfs:label": "augment Text Search",
      "rdfs:comment": "Whether to append extracted text from OCR/ASR to `textSearch`."
    },
    {
      "@id": "beckn:restrictResultsToMediaProximity",
      "@type": "rdf:Property",
      "rdfs:label": "restrict Results To Media Proximity",
      "rdfs:comment": "Restrict results to spatial proximity of media-derived coordinates (e.g., EXIF GPS tags)."
    }
  ]
}
