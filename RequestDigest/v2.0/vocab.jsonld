{
  "@context": {
    "beckn": "https://schema.beckn.io/LinkedData/v2.1/context.jsonld",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "RequestDigest": "beckn:RequestDigest",
    "digest": "beckn:digest"
  },
  "@graph": [
    {
      "@id": "beckn:RequestDigest",
      "@type": "rdfs:Class",
      "rdfs:label": "RequestDigest",
      "rdfs:comment": "A cryptographic binding that explicitly ties a callback to the\nspecific inbound request that triggered it. Establishes bilateral non-repudiation\nfor the asynchronous leg of a Beckn interaction.\n\nUse `lineage` (on `Context`) for cross-transaction causality.\n\nVerification steps:\n1. Recompute BLAKE2b-512 digest of the original request body; compare to `digest`.\n2. Confirm `messageId` matches the `messageId` from the original request `Context`.\n\nThis schema is part of the Long Term Support of Beckn Protocol V2.0 API specification and MUST NOT be extended. Any domain-specific extension must use the property of this schema which is of type Attribute."
    },
    {
      "@id": "beckn:digest",
      "@type": "rdf:Property",
      "rdfs:label": "digest",
      "rdfs:comment": "BLAKE2b-512 hash of the parent request body, Base64-encoded with algorithm prefix.\nFormat: `BLAKE-512={base64EncodedHash}`"
    }
  ]
}
